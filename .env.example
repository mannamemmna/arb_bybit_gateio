# --- TELEGRAM -------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=123456789          # Only this user can control the bot

# --- BYBIT API -------------------------------------------
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=false                 # true = testnet, false = mainnet

# --- GATE.IO API -----------------------------------------
GATEIO_API_KEY=your_gateio_api_key
GATEIO_API_SECRET=your_gateio_api_secret

# --- TRADING MODE ----------------------------------------
TRADING_MODE=paper                  # paper | live

# --- STRATEGY PARAMETERS ---------------------------------
SPREAD_ENTRY_THRESHOLD=0.5          # % minimum spread to trigger entry
SPREAD_EXIT_THRESHOLD=0.05          # % spread considered "converged" (exit)
MAX_POSITION_USDT=50                # Max size per leg (USDT)
LEVERAGE=5                          # Leverage for both exchanges
MAX_OPEN_POSITIONS=5                # Max simultaneous arb pairs

# --- ENGINE SETTINGS -------------------------------------
WS_RECONNECT_DELAY_SEC=5            # Delay before WebSocket reconnect attempt
WS_MAX_RETRIES=10                   # Max reconnect attempts before alert
WS_HEARTBEAT_SEC=20                 # Ping interval to keep WS alive
PRICE_STALENESS_MS=500              # Max age of price before signal rejected (ms)
REST_FALLBACK_INTERVAL_SEC=1.0      # Batch REST poll interval jika WS putus (2 req total)

# --- WEBSOCKET POOL --------------------------------------
# Bybit max 300 subscriptions/conn, Gate.io ~200/conn
# Pool manager membagi pair otomatis ke multiple connections
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
GATEIO_WS_URL=wss://fx-ws.gateio.ws/v4/ws/usdt
WS_MAX_SUBS_PER_CONN=250            # Batas subscription per koneksi (safety margin)

# --- FEE CONFIGURATION -----------------------------------
TAKER_FEE_BYBIT=0.0006              # 0.06% per side
TAKER_FEE_GATEIO=0.0005             # 0.05% per side
# Total round-trip cost = (0.0006 + 0.0005) � 2 legs � 2 (open+close) = 0.44%
# SPREAD_ENTRY_THRESHOLD harus > total round-trip cost + SLIPPAGE_BUFFER

# --- SLIPPAGE & EXECUTION GUARD --------------------------
SLIPPAGE_BUFFER=0.001               # 0.10% safety margin untuk estimasi slippage
PREFLIGHT_MAX_AGE_MS=500            # Tolak signal jika harga stale > 500ms saat pre-flight
PREFLIGHT_SPREAD_DECAY=0.30         # Tolak jika spread sudah turun > 30% dari recent peak
USE_ORDERBOOK_DEPTH_CHECK=true      # Aktifkan VWAP fill simulation sebelum entry
ORDERBOOK_DEPTH=5                   # Level orderbook yang dicek per exchange

# --- PAPER MODE ------------------------------------------
PAPER_INITIAL_BALANCE_USDT=1000     # Starting virtual balance
PAPER_SLIPPAGE_PCT=0.0005           # 0.05% simulated slippage per leg (opsional)

# --- LOGGING ---------------------------------------------
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/arb_bot.log

# ─── AUTO-REBALANCE ──────────────────────────────────────
REBALANCE_ENABLED=false             # true = aktif, false = matikan fitur sepenuhnya
REBALANCE_MODE=demo                 # demo | live
REBALANCE_THRESHOLD_USDT=100        # Trigger jika selisih saldo >= nilai ini (USDT)
REBALANCE_THRESHOLD_PCT=15          # ATAU jika selisih >= % dari total saldo
REBALANCE_MIN_TRANSFER=50           # Minimum transfer — tidak worth transfer di bawah ini
REBALANCE_MAX_TRANSFER=500          # Batas atas per transfer (safety)
REBALANCE_TARGET_RATIO=0.5          # Target rasio (0.5 = 50/50)
REBALANCE_CHECK_INTERVAL_SEC=300    # Cek saldo setiap 5 menit
REBALANCE_AUTO=false                # Auto-execute tanpa konfirmasi
REBALANCE_REQUIRE_CONFIRM=true      # true = user harus konfirmasi via Telegram
REBALANCE_NETWORK=TRC20             # TRC20 | ERC20 | BEP20 | ARBITRUM | OPTIMISM | BASE | POLYGON | SOLANA | TON | AVAX_C
REBALANCE_MAX_DAILY_USDT=1000       # Max total transfer per hari (safety cap)

# ─── WITHDRAWAL ADDRESSES (wajib untuk live mode) ──────
BYBIT_DEPOSIT_ADDRESS=              # Alamat deposit USDT di Bybit (terima dari Gate.io)
GATEIO_DEPOSIT_ADDRESS=             # Alamat deposit USDT di Gate.io (terima dari Bybit)